// utils.wxs - 时间格式化工具
var formatTime = function(timestamp) {
  if (!timestamp) return ''
  var date = getDate(timestamp)
  var Y = date.getFullYear()
  var M = date.getMonth() + 1
  var D = date.getDate()
  var h = date.getHours()
  var m = date.getMinutes()
  // 补零
  M = M < 10 ? '0' + M : M
  D = D < 10 ? '0' + D : D
  h = h < 10 ? '0' + h : h
  m = m < 10 ? '0' + m : m
  return Y + '-' + M + '-' + D + ' ' + h + ':' + m
}

module.exports = {
  formatTime: formatTime
}
