/* pages/orders/orders.wxss */
page { background: #f5f5f8; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
.page { padding: 16px 14px 40px; }

.page-title { font-size: 22px; font-weight: 700; color: #1a1a2e; text-align: center; margin-bottom: 16px; }

/* 手机号查询栏 */
.phone-bar {
  background: #fff; border-radius: 14px; padding: 16px;
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.phone-tip { font-size: 13px; color: #888; }
.phone-input {
  width: 100%; box-sizing: border-box; padding: 0 14px;
  height: 42px; line-height: 42px;
  background: #f8f8fb; border: 1px solid #eee; border-radius: 20px;
  font-size: 15px; text-align: center;
}
.btn-query {
  width: 100%; padding: 10px; border-radius: 20px;
  background: #e94560; color: #fff; font-size: 14px; font-weight: 600; border: none;
}

.phone-info {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 2px 12px; font-size: 13px; color: #888;
}
.change-phone { color: #e94560; font-size: 12px; }

/* 标签栏 */
.tab-bar { display: flex; background: #fff; border-radius: 10px; margin-bottom: 14px; overflow: hidden; }
.tab {
  flex: 1; text-align: center; padding: 9px 0; font-size: 13px;
  color: #999; border-bottom: 2px solid transparent;
}
.tab.active { color: #e94560; border-color: #e94560; font-weight: 600; }

/* 空状态 */
.empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 60px 0; color: #ccc;
}
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-text { font-size: 15px; color: #888; }
.empty-sub { font-size: 12px; color: #bbb; margin-top: 4px; }
.loading { text-align: center; padding: 40px; color: #999; font-size: 13px; }

/* 订单卡片 */
.order-card {
  background: #fff; border-radius: 14px; padding: 14px 16px; margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.order-id { font-size: 13px; color: #888; }
.order-status {
  font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 12px;
}
.status-pending { background: #fff3e0; color: #e67e22; }
.status-quoted { background: #e3f2fd; color: #1976d2; }
.status-paid { background: #f3e5f5; color: #8e24aa; }
.status-confirmed { background: #e8f5e9; color: #388e3c; }

.order-params { font-size: 14px; color: #333; margin-bottom: 6px; font-weight: 500; }
.order-meta { font-size: 11px; color: #aaa; display: flex; justify-content: space-between; }

/* 报价区块 */
.quote-block { background: #f8f8fb; border-radius: 10px; padding: 10px 12px; margin: 10px 0; }
.quote-row { display: flex; justify-content: space-between; font-size: 13px; color: #555; padding: 3px 0; }
.quote-total { font-weight: 700; color: #1a1a2e; }
.quote-deposit { font-size: 12px; color: #e94560; margin-top: 6px; font-weight: 600; }
.quote-tag { display: inline-block; font-size: 10px; background: #eee; color: #888; padding: 1px 6px; border-radius: 4px; margin-top: 4px; }

/* 操作按钮 */
.order-btns { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }
.btn-mini { font-size: 12px; color: #666; background: #f0f0f0; border: none; border-radius: 6px; }
.btn-confirm { font-size: 12px; color: #fff; background: #e94560; border: none; border-radius: 6px; }

/* 报价弹窗 */
.quote-popup { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; }
.popup-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.55); }
.popup-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 20px 20px 0 0;
  max-height: 88vh; overflow-y: auto;
  animation: slideUp 0.25s ease;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

.popup-hd {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 18px 14px;
  border-bottom: 1px solid #f0f0f0;
  font-size: 16px; font-weight: 700; color: #1a1a2e;
}
.popup-close { color: #ccc; font-size: 20px; padding: 0 4px; }

.popup-body { padding: 16px 18px 40px; }

.popup-body .quote-row { font-size: 14px; padding: 6px 0; }
.popup-body .total { font-size: 16px; font-weight: 700; color: #e94560; }

.quote-deposit {
  background: linear-gradient(135deg,#fff3e0,#ffe0b2);
  border-radius: 10px; padding: 10px 14px;
  font-size: 14px; color: #e67e22; font-weight: 700; margin: 12px 0;
}
.quote-note { font-size: 13px; color: #888; margin-top: 8px; }

/* 支付宝收款 */
.pay-section {
  margin-top: 20px; padding: 18px;
  background: linear-gradient(135deg,#f0fff4,#e8f5e9);
  border-radius: 14px; text-align: center;
}
.pay-title { font-size: 16px; font-weight: 700; color: #27ae60; margin-bottom: 14px; }
.qr-img {
  width: 220px; height: 220px; border-radius: 12px;
  margin: 0 auto 10px; display: block;
  border: 3px solid #27ae60;
}
.pay-tip { font-size: 12px; color: #666; margin-bottom: 6px; }
.pay-amount {
  font-size: 14px; color: #27ae60; font-weight: 700; margin: 8px 0;
  background: #fff; border-radius: 8px; padding: 8px;
}
.btn-pay {
  margin-top: 12px; background: #27ae60; color: #fff;
  font-size: 14px; font-weight: 600; border: none; border-radius: 10px;
  padding: 10px;
}
