/* pages/index/index.wxss */
page { background: #f5f5f8; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }

.page { padding: 16px 14px 40px; }

.page-title { font-size: 22px; font-weight: 700; color: #1a1a2e; text-align: center; margin-bottom: 4px; }
.page-sub { font-size: 12px; color: #999; text-align: center; margin-bottom: 16px; }

/* 入口导航 */
.entry-nav {
  display: flex; gap: 12px; margin-bottom: 16px;
}
.entry-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 8px; padding: 14px 0; border-radius: 14px;
  font-weight: 600; font-size: 15px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.entry-orders {
  background: #fff; color: #1976d2; border: 1px solid #e3f2fd;
}
.entry-admin {
  background: #fff; color: #e94560; border: 1px solid #fce4ec;
}
.entry-icon { font-size: 20px; }
.entry-label { font-size: 14px; }

.card {
  background: #fff;
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.card-header { font-size: 13px; font-weight: 600; color: #1a1a2e; margin-bottom: 10px; }
.card-row { display: flex; gap: 12px; }
.card-row-item { flex: 1; }
.card-row-item .card-header { font-size: 12px; }

.picker-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 12px;
  background: #f8f8fb;
  border-radius: 8px;
  border: 1px solid #eee;
  font-size: 14px;
  color: #333;
}
.picker-row .arrow { font-size: 10px; color: #999; }

.form-input {
  width: 100%;
  box-sizing: border-box;
  padding: 0 12px;
  height: 40px;
  line-height: 40px;
  background: #f8f8fb;
  border: 1px solid #eee;
  border-radius: 8px;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}
.input-placeholder {
  color: #999;
}
.form-input:last-child { margin-bottom: 0; }

.contact-fields .form-input { margin-bottom: 8px; }

.chip-wrap { }
.chip { display: inline-block; padding: 6px 14px; border-radius: 20px; font-size: 13px; margin: 4px 6px 4px 0; border: 1px solid #eee; background: #f8f8fb; color: #555; }
.chip.active { background: #e94560; color: #fff; border-color: #e94560; }

.return-sample-wrap .checkbox-label { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #333; padding: 6px 0; }
.return-sample-wrap .form-input { margin-top: 8px; }

.hint { font-size: 11px; color: #aaa; margin-top: 4px; }

.submit-wrap { margin-top: 20px; }
.btn-submit {
  width: 100%; padding: 14px; border-radius: 30px;
  background: linear-gradient(135deg, #e94560, #c7365b);
  color: #fff; font-size: 16px; font-weight: 700;
  border: none; letter-spacing: 1px;
}
.btn-hover { opacity: 0.85; }
