/* pages/admin/admin.wxss */
page { background: #f5f5f8; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
.page { padding: 16px 14px 40px; }

/* 登录卡片 */
.login-card {
  background: #fff; border-radius: 16px; padding: 40px 24px;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}
.login-icon { font-size: 48px; margin-bottom: 12px; }
.login-title { font-size: 20px; font-weight: 700; color: #1a1a2e; margin-bottom: 24px; }
.login-input {
  width: 100%; box-sizing: border-box; padding: 0 16px;
  height: 44px; line-height: 44px;
  background: #f8f8fb; border: 1px solid #eee; border-radius: 10px;
  font-size: 15px; margin-bottom: 14px; text-align: center;
}
.btn-login {
  width: 100%; padding: 12px; border-radius: 25px;
  background: #e94560; color: #fff; font-size: 15px; font-weight: 600; border: none;
}

/* 商家头部 */
.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.admin-header text:first-child { font-size: 18px; font-weight: 700; color: #1a1a2e; }
.logout { font-size: 13px; color: #e94560; }

/* 标签栏 */
.tab-bar { display: flex; background: #fff; border-radius: 10px; margin-bottom: 14px; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 10px 0; font-size: 13px; color: #999; border-bottom: 2px solid transparent; }
.tab.active { color: #e94560; border-color: #e94560; font-weight: 600; }

/* 空状态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 60px 0; color: #ccc; }
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.loading { text-align: center; padding: 40px; color: #999; font-size: 13px; }

/* 订单卡片 */
.order-card { background: #fff; border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.order-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
.order-id { font-size: 13px; color: #888; display: block; }
.order-time { font-size: 11px; color: #aaa; display: block; }
.order-status { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 12px; }
.status-pending { background: #fff3e0; color: #e67e22; }
.status-quoted { background: #e3f2fd; color: #1976d2; }
.status-paid { background: #f3e5f5; color: #8e24aa; }
.status-confirmed { background: #e8f5e9; color: #388e3c; }

/* 参数网格 */
.params-grid { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
.params-grid text { font-size: 11px; color: #555; background: #f5f5f8; padding: 2px 7px; border-radius: 4px; }
.params-grid text.full { width: 100%; }

.divider { height: 1px; background: #f0f0f0; margin: 10px 0; }

/* 联系信息 */
.contact-block { font-size: 12px; color: #666; margin-bottom: 6px; }
.contact-company { font-weight: 600; color: #333; display: block; margin-bottom: 2px; }
.addr-block { font-size: 12px; color: #888; margin-bottom: 6px; word-break: break-all; }
.sample-block { font-size: 11px; color: #e67e22; background: #fff8e1; padding: 6px 10px; border-radius: 6px; margin-bottom: 6px; }

/* 已报价区块 */
.quoted-block { background: #f0f9ff; border-radius: 10px; padding: 10px 12px; margin: 8px 0; }
.quote-row { display: flex; justify-content: space-between; font-size: 12px; color: #555; padding: 3px 0; }
.quote-row .total { font-weight: 700; color: #1a1a2e; }
.quote-row .deposit { font-weight: 700; color: #e94560; }
.quote-note { font-size: 11px; color: #888; margin-top: 6px; }
.confirmed-tag { font-size: 12px; color: #388e3c; font-weight: 600; margin-top: 6px; }

/* 报价表单 */
.quote-form { background: #fff9f0; border-radius: 10px; padding: 12px 14px; margin-top: 10px; border: 1px solid #ffe0b2; }
.quote-title { font-size: 13px; font-weight: 600; color: #e67e22; margin-bottom: 10px; }
.form-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.form-row text { font-size: 12px; color: #888; width: 60px; flex-shrink: 0; }
.qi-input {
  flex: 1; padding: 0 10px; height: 34px; line-height: 34px;
  background: #fff; border: 1px solid #eee;
  border-radius: 8px; font-size: 13px;
}
.qi-picker { flex: 1; padding: 7px 10px; background: #fff; border: 1px solid #eee; border-radius: 8px; font-size: 13px; color: #333; }

.calc-preview { background: #fff3e0; border-radius: 8px; padding: 8px 12px; margin: 8px 0; }
.calc-preview view { font-size: 12px; color: #555; padding: 2px 0; }
.calc-preview .total { font-weight: 700; color: #e67e22; }
.calc-preview .deposit { font-weight: 700; color: #e94560; }

.btn-quote {
  width: 100%; margin-top: 10px; padding: 10px; border-radius: 20px;
  background: #e67e22; color: #fff; font-size: 14px; font-weight: 600; border: none;
}

/* 付款审核区 */
.payment-review {
  background: #f3e5f5; border-radius: 10px; padding: 12px 14px; margin-top: 10px;
  border: 1px solid #e1bee7;
}
.review-title { font-size: 13px; font-weight: 600; color: #8e24aa; margin-bottom: 10px; }
.proof-actions { display: flex; gap: 8px; }
.btn-preview {
  font-size: 12px; color: #8e24aa; background: #fff; border: 1px solid #ce93d8; border-radius: 6px;
}
.btn-confirm-pay {
  font-size: 12px; color: #fff; background: #8e24aa; border: none; border-radius: 6px;
}

/* 头部操作区 */
.header-actions { display: flex; align-items: center; gap: 12px; }
.copy-merchant { font-size: 13px; color: #1976d2; }